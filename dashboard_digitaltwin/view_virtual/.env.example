# Dashboard Environment Configuration
# Data source: Azure IoT Hub via Azure Function (no external MQTT broker needed)

# Azure Function URL (for sensor data from Azure IoT Hub)
VITE_AZURE_FUNCTION_URL=https://your-function-app.azurewebsites.net/api

# Camera Stream URL (Raspberry Pi streaming server)
# Format: http://<raspberry-pi-ip>:5000
# Lihat CAMERA_SETUP.md untuk panduan setup
VITE_CAMERA_STREAM_URL=
# Function key khusus endpoint write protected (people/save, sensor/save)
VITE_AZURE_FUNCTION_WRITE_KEY=

# Firebase Authentication
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
# Opsional: fallback username -> username@domain-anda.com
VITE_AUTH_DEFAULT_DOMAIN=
# Opsional: fallback admin lokal untuk development jika Email/Password Firebase belum aktif
VITE_LOCAL_ADMIN_EMAIL=
VITE_LOCAL_ADMIN_PASSWORD=
VITE_LOCAL_ADMIN_NAME=TwinSpace Admin
# Opsional: allowlist email admin (dipisah koma), contoh: admin1@company.com,admin2@company.com
VITE_ADMIN_EMAILS=
# Durasi sesi admin (menit), default 30
VITE_ADMIN_SESSION_TTL_MINUTES=30

# Polling interval in milliseconds (default: 5000 = 5 seconds)
# VITE_POLLING_INTERVAL=5000

#ccamera stream url
VITE_CAMERA_STREAM_URL=

# Demo Mode (set to 'false' for real data from Azure IoT Hub)
VITE_DEMO_MODE=false

