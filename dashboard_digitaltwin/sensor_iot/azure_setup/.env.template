# Azure Digital Twins Environment Configuration
# Copy this file to .env and fill in your actual values

# ===== Azure Resources =====
AZURE_SUBSCRIPTION_ID=your-subscription-id-here
RESOURCE_GROUP=rg-digitaltwin-energymonitor
LOCATION=southeastasia

# ===== Azure IoT Hub =====
IOT_HUB_NAME=your-iothub-name
IOT_HUB_CONNECTION_STRING=HostName=your-iothub.azure-devices.net;SharedAccessKeyName=iothubowner;SharedAccessKey=xxxxx
DEVICE_ID=ESP32_ENERGY_MONITOR_001
DEVICE_CONNECTION_STRING=HostName=your-iothub.azure-devices.net;DeviceId=ESP32_ENERGY_MONITOR_001;SharedAccessKey=xxxxx

# ===== Azure Digital Twins =====
ADT_INSTANCE_NAME=your-adt-instance-name
ADT_INSTANCE_URL=https://your-adt-instance.api.sea.digitaltwins.azure.net

# ===== Azure Function =====
FUNCTION_APP_NAME=your-function-app-name
AZURE_FUNCTION_URL=https://your-function-app.azurewebsites.net/api/MqttToIoTHub
AZURE_FUNCTION_KEY=your-function-key-here

# ===== HiveMQ Cloud =====
HIVEMQ_CLUSTER_URL=your-hivemq-cluster-url
HIVEMQ_USERNAME=your-hivemq-username
HIVEMQ_PASSWORD=your-hivemq-password
HIVEMQ_MQTT_TOPIC=sensor/dht11/data

# ===== Storage =====
STORAGE_ACCOUNT_NAME=your-storage-account
STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=xxxxx;AccountKey=xxxxx;EndpointSuffix=core.windows.net

# ===== Optional: Time Series Insights =====
TSI_ENVIRONMENT_NAME=tsi-energymonitor
TSI_ENVIRONMENT_ID=your-tsi-environment-id

# ===== Development =====
LOG_LEVEL=info
ENABLE_DEBUG=false
